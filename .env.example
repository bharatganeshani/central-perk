# ------------------------------------------------------------------------------
# CENTRAL PERK ENVIRONMENT VARIABLES TEMPLATE
# Copy to .env.local or .env for production deployment.
# ------------------------------------------------------------------------------

# Auth Configuration
NEXTAUTH_SECRET=central-perk-secret-key-991208a
NEXTAUTH_URL=http://localhost:3000

# Database Configuration (PostgreSQL with Prisma)
# Un-comment and set to point to your live PostgreSQL database.
# If omitted, Central Perk automatically falls back to workspace-local JSON file storage.
# DATABASE_URL="postgresql://username:password@localhost:5432/central_perk?schema=public"

# AWS S3 Storage Config (For raw file uploads)
# If omitted, uploads are simulated and stored locally.
AWS_ACCESS_KEY_ID=your-aws-access-key-id
AWS_SECRET_ACCESS_KEY=your-aws-secret-key
AWS_BUCKET_NAME=central-perk-uploads
AWS_REGION=us-east-1

# AI & NLP Integrity Classifiers
# If set, GPT-4o will parse resumes and verify digital signatures.
# If omitted, Central Perk runs local lexical scoring heuristics.
OPENAI_API_KEY=your-openai-api-key
HUGGINGFACE_API_KEY=your-huggingface-api-key # Optional

# Upstash Redis Rate Limiting (Optional)
UPSTASH_REDIS_REST_URL=your-upstash-redis-url
UPSTASH_REDIS_REST_TOKEN=your-upstash-redis-token
